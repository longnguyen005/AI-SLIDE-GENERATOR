PORT=5000
MONGODB_URI=mongodb://localhost:27017/deckai
JWT_SECRET=replace-with-a-long-secret
CORS_ORIGIN=http://localhost:5173
# Single key (backward compatible)
GEMINI_API_KEY=
# Multiple keys for rotation (comma-separated, takes priority over GEMINI_API_KEY)
GEMINI_API_KEYS=
# Fallback model chain (comma-separated, default: gemini-2.5-flash,gemini-2.5-pro,gemini-2.0-flash)
GEMINI_MODELS=gemini-2.5-flash,gemini-2.5-pro,gemini-2.0-flash
DNS_SERVERS=8.8.8.8,1.1.1.1
